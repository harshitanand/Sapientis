# ──────────────────────────────────────────────
#  Movie Ticket Booking Platform — Local Config
# ──────────────────────────────────────────────

# Application
APP_PORT=8080

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=movie_booking
DB_USERNAME=booking_user
DB_PASSWORD=booking_pass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=kafka:29092

# Seat lock TTL (minutes)
SEAT_LOCK_TTL_MINUTES=10

# JWT — replace with a 256-bit random secret in production
JWT_SECRET=change_me_to_a_secure_256bit_random_string_in_production
